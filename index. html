<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Loops Experiment</title>
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#0f1117">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Loops">
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap');

  :root {
    --bg: #0f1117;
    --surface: #181c27;
    --surface2: #1e2335;
    --border: #2a3050;
    --accent: #5b8ef0;
    --accent-dim: rgba(91,142,240,0.12);
    --accent2: #a78bfa;
    --text: #e8eaf0;
    --text-dim: #7a8099;
    --text-muted: #4a5175;
    --on: #34d399;
    --on-dim: rgba(52,211,153,0.12);
    --warn: #f59e0b;
    --radius: 10px;
    --radius-sm: 6px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
    padding: 0 0 60px;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px 16px;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 100;
  }
  .nav-title {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .nav-tabs {
    display: flex;
    gap: 2px;
    background: var(--surface);
    border-radius: var(--radius-sm);
    padding: 3px;
  }
  .nav-tab {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    padding: 5px 12px;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    transition: all 0.15s;
    background: transparent;
    color: var(--text-dim);
  }
  .nav-tab.active {
    background: var(--surface2);
    color: var(--text);
  }
  .view { display: none; padding: 24px; max-width: 600px; margin: 0 auto; }
  .view.active { display: block; }

  .day-header { margin-bottom: 28px; }
  .day-label {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .day-date {
    font-size: 24px;
    font-weight: 300;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .loop-toggle-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 18px;
    margin-bottom: 28px;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .loop-toggle-row.active-tappi {
    border-color: var(--on);
    background: var(--on-dim);
  }
  .loop-label { font-size: 14px; font-weight: 500; }
  .loop-label small {
    display: block;
    font-size: 12px;
    font-weight: 300;
    color: var(--text-dim);
    margin-top: 2px;
  }
  .toggle-pill {
    width: 44px; height: 24px;
    background: var(--border);
    border-radius: 12px;
    position: relative;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .toggle-pill::after {
    content: '';
    position: absolute;
    top: 3px; left: 3px;
    width: 18px; height: 18px;
    background: #fff;
    border-radius: 50%;
    transition: transform 0.2s;
  }
  .active-tappi .toggle-pill { background: var(--on); }
  .active-tappi .toggle-pill::after { transform: translateX(20px); }

  .section-title {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 14px;
  }

  .metric-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px;
    margin-bottom: 16px;
  }
  .metric-name { font-size: 14px; font-weight: 500; margin-bottom: 4px; }
  .metric-desc { font-size: 12px; color: var(--text-dim); margin-bottom: 16px; font-style: italic; }

  .scale-row { display: flex; gap: 6px; align-items: center; justify-content: space-between; }
  .scale-btn {
    flex: 1;
    height: 36px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-dim);
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .scale-btn.sel-focus {
    background: var(--accent-dim);
    border-color: var(--accent);
    color: var(--accent);
    font-weight: 500;
  }
  .scale-btn.sel-stress {
    background: rgba(167,139,250,0.12);
    border-color: var(--accent2);
    color: var(--accent2);
    font-weight: 500;
  }
  .scale-labels { display: flex; justify-content: space-between; margin-top: 6px; font-size: 11px; color: var(--text-muted); }

  .note-area {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px;
    margin-bottom: 16px;
  }
  textarea {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    line-height: 1.7;
    resize: none;
    min-height: 80px;
  }
  textarea::placeholder { color: var(--text-muted); font-style: italic; }

  .chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
  .chip {
    font-size: 12px;
    font-family: 'DM Mono', monospace;
    padding: 5px 12px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.15s;
  }
  .chip.selected { background: var(--accent-dim); border-color: var(--accent); color: var(--accent); }

  .save-btn {
    width: 100%;
    height: 48px;
    background: var(--accent);
    border: none;
    border-radius: var(--radius);
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .save-btn:hover { opacity: 0.85; }
  .saved-msg { text-align: center; font-size: 13px; color: var(--on); margin-top: 10px; height: 20px; font-family: 'DM Mono', monospace; }

  .progress-header { margin-bottom: 28px; }
  .progress-title { font-size: 20px; font-weight: 300; letter-spacing: -0.01em; margin-bottom: 4px; }
  .progress-sub { font-size: 13px; color: var(--text-dim); font-family: 'DM Mono', monospace; }

  .stat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px; }
  .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; }
  .stat-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }
  .stat-val { font-size: 28px; font-weight: 300; letter-spacing: -0.02em; }
  .stat-val span { font-size: 13px; color: var(--text-dim); font-weight: 400; }
  .stat-delta { font-size: 12px; margin-top: 4px; font-family: 'DM Mono', monospace; }
  .delta-up { color: var(--on); }
  .delta-down { color: #f87171; }

  .chart-block { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; margin-bottom: 16px; }
  .chart-title { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 16px; }
  canvas { width: 100% !important; }

  .log-list { display: flex; flex-direction: column; gap: 10px; }
  .log-item { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 16px; }
  .log-item-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
  .log-item-date { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text-dim); }
  .log-item-tappi { font-family: 'DM Mono', monospace; font-size: 10px; padding: 2px 8px; border-radius: 20px; background: var(--on-dim); color: var(--on); }
  .log-item-tappi.no { background: var(--surface2); color: var(--text-muted); }
  .log-item-scores { display: flex; gap: 16px; font-size: 13px; color: var(--text-dim); font-family: 'DM Mono', monospace; }
  .log-item-note { margin-top: 8px; font-size: 13px; color: var(--text-dim); font-style: italic; border-top: 1px solid var(--border); padding-top: 8px; }
  .context-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 6px; }
  .context-tag { font-size: 10px; font-family: 'DM Mono', monospace; padding: 2px 8px; border-radius: 20px; background: var(--accent-dim); color: var(--accent); }

  .corr-block { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; margin-bottom: 16px; }
  .corr-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--border); }
  .corr-row:last-child { border-bottom: none; }
  .corr-label { font-size: 13px; color: var(--text-dim); }
  .corr-vals { display: flex; gap: 20px; font-family: 'DM Mono', monospace; font-size: 13px; }
  .corr-on { color: var(--on); }
  .corr-off { color: var(--text-muted); }

  .insight { background: var(--accent-dim); border: 1px solid rgba(91,142,240,0.25); border-radius: var(--radius); padding: 14px 16px; margin-bottom: 16px; font-size: 13px; line-height: 1.6; }
  .insight strong { color: var(--accent); font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 4px; }
  .empty-state { text-align: center; padding: 48px 0; color: var(--text-muted); font-size: 14px; font-style: italic; }
</style>
</head>
<body>
<nav class="nav">
  <span class="nav-title">Loops Quiet / 30gg</span>
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="showView('log')">Registra</button>
    <button class="nav-tab" onclick="showView('progress')">Andamento</button>
    <button class="nav-tab" onclick="showView('history')">Storico</button>
  </div>
</nav>

<div id="view-log" class="view active">
  <div class="day-header">
    <div class="day-label">Oggi</div>
    <div class="day-date" id="today-date">—</div>
  </div>
  <div class="loop-toggle-row" id="tappi-toggle" onclick="toggleTappi()">
    <div class="loop-label">
      Loops indossati
      <small>Ho usato i tappi oggi?</small>
    </div>
    <div class="toggle-pill"></div>
  </div>
  <p class="section-title">Concentrazione / focus</p>
  <div class="metric-block">
    <div class="metric-name">Quanto riesci a mantenere l'attenzione?</div>
    <div class="metric-desc">1 = mente dispersa · 10 = focus totale</div>
    <div class="scale-row" id="scale-focus"></div>
    <div class="scale-labels"><span>dispersa</span><span>focalizzata</span></div>
  </div>
  <p class="section-title">Livello di stress / attivazione</p>
  <div class="metric-block">
    <div class="metric-name">Quanto senti attivato il sistema nervoso?</div>
    <div class="metric-desc">1 = calmo · 10 = attivazione intensa</div>
    <div class="scale-row" id="scale-stress"></div>
    <div class="scale-labels"><span>calmo</span><span>molto attivato</span></div>
  </div>
  <p class="section-title">Contesto</p>
  <div class="chips">
    <button class="chip" data-ctx="casa rumorosa" onclick="toggleChip(this)">casa rumorosa</button>
    <button class="chip" data-ctx="lavoro" onclick="toggleChip(this)">lavoro / scrittura</button>
    <button class="chip" data-ctx="telefonate" onclick="toggleChip(this)">telefonate</button>
    <button class="chip" data-ctx="bambini" onclick="toggleChip(this)">bambini in casa</button>
    <button class="chip" data-ctx="fuori casa" onclick="toggleChip(this)">fuori casa</button>
    <button class="chip" data-ctx="routine mattina" onclick="toggleChip(this)">routine mattina</button>
    <button class="chip" data-ctx="serata" onclick="toggleChip(this)">serata</button>
    <button class="chip" data-ctx="giornata difficile" onclick="toggleChip(this)">giornata difficile</button>
  </div>
  <p class="section-title">Nota libera</p>
  <div class="note-area">
    <textarea id="entry-note" rows="3" placeholder="cosa osservi oggi?"></textarea>
  </div>
  <button class="save-btn" onclick="saveEntry()">Salva giornata</button>
  <div class="saved-msg" id="saved-msg"></div>
</div>

<div id="view-progress" class="view">
  <div class="progress-header">
    <div class="progress-title">Andamento esperimento</div>
    <div class="progress-sub" id="progress-range">—</div>
  </div>
  <div id="insight-box"></div>
  <div class="stat-row" id="stat-row"></div>
  <div class="chart-block">
    <div class="chart-title">Focus nel tempo</div>
    <canvas id="chart-focus" height="120"></canvas>
  </div>
  <div class="chart-block">
    <div class="chart-title">Stress / attivazione nel tempo</div>
    <canvas id="chart-stress" height="120"></canvas>
  </div>
  <div class="corr-block">
    <div class="chart-title">Tappi sì vs tappi no — medie</div>
    <div id="corr-rows"></div>
  </div>
</div>

<div id="view-history" class="view">
  <div class="progress-header">
    <div class="progress-title">Storico registrazioni</div>
  </div>
  <div class="log-list" id="history-list"></div>
</div>
<script>
const STORAGE_KEY = 'loops_experiment_v1';
let state = { tappiOn: false, focusVal: null, stressVal: null, chips: [] };
let data = {};

function init() {
  try {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved) data = JSON.parse(saved);
  } catch(e) { data = {}; }
  const today = todayKey();
  if (data[today]) {
    const d = data[today];
    state.tappiOn = d.tappi;
    state.focusVal = d.focus;
    state.stressVal = d.stress;
    state.chips = d.chips || [];
    document.getElementById('entry-note').value = d.note || '';
  }
  renderDate();
  buildScales();
  renderTappiToggle();
  renderChips();
}

function todayKey() { return new Date().toISOString().split('T')[0]; }
function todayDisplay() { return new Date().toLocaleDateString('it-IT', { weekday:'long', day:'numeric', month:'long', year:'numeric' }); }
function renderDate() { document.getElementById('today-date').textContent = todayDisplay(); }

function buildScales() { buildScale('scale-focus','focus'); buildScale('scale-stress','stress'); }
function buildScale(containerId, type) {
  const container = document.getElementById(containerId);
  container.innerHTML = '';
  for (let i = 1; i <= 10; i++) {
    const btn = document.createElement('button');
    btn.className = 'scale-btn';
    btn.textContent = i;
    btn.onclick = () => selectScale(type, i);
    container.appendChild(btn);
  }
  renderScale(type);
}
function renderScale(type) {
  const val = type === 'focus' ? state.focusVal : state.stressVal;
  const container = document.getElementById('scale-' + type);
  container.querySelectorAll('.scale-btn').forEach((btn, i) => {
    btn.classList.toggle('sel-' + type, (i + 1) === val);
  });
}
function selectScale(type, val) {
  if (type === 'focus') state.focusVal = val;
  else state.stressVal = val;
  renderScale(type);
}

function toggleTappi() { state.tappiOn = !state.tappiOn; renderTappiToggle(); }
function renderTappiToggle() { document.getElementById('tappi-toggle').classList.toggle('active-tappi', state.tappiOn); }

function toggleChip(el) {
  const ctx = el.dataset.ctx;
  if (state.chips.includes(ctx)) { state.chips = state.chips.filter(c => c !== ctx); el.classList.remove('selected'); }
  else { state.chips.push(ctx); el.classList.add('selected'); }
}
function renderChips() { document.querySelectorAll('.chip').forEach(chip => { chip.classList.toggle('selected', state.chips.includes(chip.dataset.ctx)); }); }

function saveEntry() {
  if (state.focusVal === null || state.stressVal === null) {
    const msg = document.getElementById('saved-msg');
    msg.style.color = 'var(--warn)';
    msg.textContent = '→ compila entrambe le scale prima di salvare';
    return;
  }
  const today = todayKey();
  data[today] = { tappi: state.tappiOn, focus: state.focusVal, stress: state.stressVal, chips: [...state.chips], note: document.getElementById('entry-note').value.trim(), ts: new Date().toISOString() };
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    const msg = document.getElementById('saved-msg');
    msg.style.color = 'var(--on)';
    msg.textContent = '✓ salvato';
    setTimeout(() => { msg.textContent = ''; }, 2500);
  } catch(e) { document.getElementById('saved-msg').textContent = 'errore nel salvataggio'; }
}

function showView(name) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('view-' + name).classList.add('active');
  event.target.classList.add('active');
  if (name === 'progress') renderProgress();
  if (name === 'history') renderHistory();
}

function renderProgress() {
  const entries = Object.entries(data).sort(([a],[b]) => a.localeCompare(b));
  const rangeEl = document.getElementById('progress-range');
  if (entries.length === 0) { rangeEl.textContent = 'nessuna registrazione ancora'; document.getElementById('stat-row').innerHTML = ''; document.getElementById('corr-rows').innerHTML = ''; document.getElementById('insight-box').innerHTML = ''; return; }
  const dayCount = entries.length;
  rangeEl.textContent = `${dayCount} giornata${dayCount > 1 ? 'e' : ''} registrata${dayCount > 1 ? 'e' : ''} su 30`;
  const avg = (arr) => arr.length ? (arr.reduce((a,b) => a+b, 0) / arr.length).toFixed(1) : '—';
  const allFocus = entries.map(([,d]) => d.focus);
  const allStress = entries.map(([,d]) => d.stress);
  const tappiDays = entries.filter(([,d]) => d.tappi);
  const half = Math.floor(entries.length / 2);
  const focusDelta = (() => { const f1 = entries.slice(0,half).map(([,d])=>d.focus); const f2 = entries.slice(half).map(([,d])=>d.focus); return (f1.length && f2.length) ? (f2.reduce((a,b)=>a+b,0)/f2.length - f1.reduce((a,b)=>a+b,0)/f1.length).toFixed(1) : null; })();
  const stressDelta = (() => { const s1 = entries.slice(0,half).map(([,d])=>d.stress); const s2 = entries.slice(half).map(([,d])=>d.stress); return (s1.length && s2.length) ? (s2.reduce((a,b)=>a+b,0)/s2.length - s1.reduce((a,b)=>a+b,0)/s1.length).toFixed(1) : null; })();
  document.getElementById('stat-row').innerHTML = `<div class="stat-card"><div class="stat-label">Focus medio</div><div class="stat-val">${avg(allFocus)} <span>/ 10</span></div>${focusDelta !== null ? `<div class="stat-delta ${focusDelta > 0 ? 'delta-up' : 'delta-down'}">${focusDelta > 0 ? '+' : ''}${focusDelta} tendenza</div>` : ''}</div><div class="stat-card"><div class="stat-label">Stress medio</div><div class="stat-val">${avg(allStress)} <span>/ 10</span></div>${stressDelta !== null ? `<div class="stat-delta ${stressDelta < 0 ? 'delta-up' : 'delta-down'}">${stressDelta > 0 ? '+' : ''}${stressDelta} tendenza</div>` : ''}</div><div class="stat-card"><div class="stat-label">Giorni con tappi</div><div class="stat-val">${tappiDays.length} <span>gg</span></div></div><div class="stat-card"><div class="stat-label">Completamento</div><div class="stat-val">${Math.round(dayCount/30*100)}<span>%</span></div></div>`;
  const insightBox = document.getElementById('insight-box');
  if (entries.length >= 5) {
    const tF = entries.filter(([,d])=>d.tappi).map(([,d])=>d.focus);
    const nF = entries.filter(([,d])=>!d.tappi).map(([,d])=>d.focus);
    const tS = entries.filter(([,d])=>d.tappi).map(([,d])=>d.stress);
    const nS = entries.filter(([,d])=>!d.tappi).map(([,d])=>d.stress);
    if (tF.length > 0 && nF.length > 0) {
      const fD = (tF.reduce((a,b)=>a+b,0)/tF.length - nF.reduce((a,b)=>a+b,0)/nF.length).toFixed(1);
      const sD = (tS.reduce((a,b)=>a+b,0)/tS.length - nS.reduce((a,b)=>a+b,0)/nS.length).toFixed(1);
      insightBox.innerHTML = `<div class="insight"><strong>Osservazione dati</strong>Nei giorni con tappi, il focus risulta <b>${fD > 0 ? 'più alto' : 'più basso'}</b> di ${Math.abs(fD)} punti e lo stress <b>${sD < 0 ? 'più basso' : 'più alto'}</b> di ${Math.abs(sD)} punti. Dati provvisori.</div>`;
    }
  } else { insightBox.innerHTML = `<div class="insight"><strong>Nota</strong>Servono almeno 5 registrazioni per vedere i pattern.</div>`; }
  drawChart('chart-focus', entries, 'focus', '#5b8ef0');
  drawChart('chart-stress', entries, 'stress', '#a78bfa');
  renderCorr(entries);
}

function drawChart(canvasId, entries, field, color) {
  const canvas = document.getElementById(canvasId);
  const ctx = canvas.getContext('2d');
  const W = canvas.offsetWidth || 320; const H = 120;
  canvas.width = W*2; canvas.height = H*2; canvas.style.width = W+'px'; canvas.style.height = H+'px';
  ctx.scale(2,2); ctx.clearRect(0,0,W,H);
  const vals = entries.map(([,d])=>d[field]);
  const tappiArr = entries.map(([,d])=>d.tappi);
  const labels = entries.map(([k])=>k.slice(5));
  const padL=28,padR=12,padT=10,padB=24,cW=W-padL-padR,cH=H-padT-padB;
  ctx.strokeStyle='#2a3050'; ctx.lineWidth=0.5;
  for(let i=0;i<=10;i+=2){const y=padT+cH-(i/10)*cH; ctx.beginPath();ctx.moveTo(padL,y);ctx.lineTo(padL+cW,y);ctx.stroke(); ctx.fillStyle='#4a5175';ctx.font='8px DM Mono';ctx.fillText(i,2,y+3);}
  if(vals.length<2){const x=padL+cW/2,y=padT+cH-(vals[0]/10)*cH;ctx.beginPath();ctx.arc(x,y,4,0,Math.PI*2);ctx.fillStyle=color;ctx.fill();return;}
  const step=cW/(vals.length-1);
  tappiArr.forEach((t,i)=>{if(t){const x1=padL+i*step-step/2,x2=padL+i*step+step/2;ctx.fillStyle='rgba(52,211,153,0.06)';ctx.fillRect(Math.max(padL,x1),padT,Math.min(x2,padL+cW)-Math.max(padL,x1),cH);}});
  ctx.beginPath();vals.forEach((v,i)=>{const x=padL+i*step,y=padT+cH-(v/10)*cH;i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});ctx.strokeStyle=color;ctx.lineWidth=1.5;ctx.stroke();
  vals.forEach((v,i)=>{const x=padL+i*step,y=padT+cH-(v/10)*cH;ctx.beginPath();ctx.arc(x,y,2.5,0,Math.PI*2);ctx.fillStyle=tappiArr[i]?'#34d399':color;ctx.fill();});
  ctx.fillStyle='#4a5175';ctx.font='7px DM Mono';
  const step2=Math.floor(vals.length/Math.min(5,vals.length));
  labels.forEach((l,i)=>{if(i%Math.max(1,step2)===0){ctx.fillText(l,padL+i*step-8,H-4);}});
}

function renderCorr(entries) {
  const on=entries.filter(([,d])=>d.tappi),off=entries.filter(([,d])=>!d.tappi);
  const avg=arr=>arr.length?(arr.reduce((a,b)=>a+b,0)/arr.length).toFixed(1):'—';
  document.getElementById('corr-rows').innerHTML = `<div class="corr-row"><span class="corr-label"></span><div class="corr-vals"><span class="corr-on">● tappi on</span><span class="corr-off">○ tappi off</span></div></div><div class="corr-row"><span class="corr-label">Focus</span><div class="corr-vals"><span class="corr-on">${avg(on.map(([,d])=>d.focus))}</span><span class="corr-off">${avg(off.map(([,d])=>d.focus))}</span></div></div><div class="corr-row"><span class="corr-label">Stress</span><div class="corr-vals"><span class="corr-on">${avg(on.map(([,d])=>d.stress))}</span><span class="corr-off">${avg(off.map(([,d])=>d.stress))}</span></div></div><div class="corr-row"><span class="corr-label" style="font-size:11px;color:var(--text-muted)">Giorni</span><div class="corr-vals" style="font-size:11px"><span class="corr-on">${on.length}</span><span class="corr-off">${off.length}</span></div></div>`;
}

function renderHistory() {
  const entries = Object.entries(data).sort(([a],[b])=>b.localeCompare(a));
  const container = document.getElementById('history-list');
  if(entries.length===0){container.innerHTML='<div class="empty-state">nessuna registrazione ancora</div>';return;}
  container.innerHTML=entries.map(([key,d])=>{
    const dateStr=new Date(key+'T12:00:00').toLocaleDateString('it-IT',{weekday:'short',day:'numeric',month:'short'});
    return `<div class="log-item"><div class="log-item-top"><span class="log-item-date">${dateStr}</span><span class="log-item-tappi ${d.tappi?'':'no'}">${d.tappi?'tappi ●':'tappi ○'}</span></div><div class="log-item-scores"><span>focus <b>${d.focus}</b>/10</span><span>stress <b>${d.stress}</b>/10</span></div>${d.chips&&d.chips.length?`<div class="context-tags">${d.chips.map(c=>`<span class="context-tag">${c}</span>`).join('')}</div>`:''} ${d.note?`<div class="log-item-note">${d.note}</div>`:''}</div>`;
  }).join('');
}

init();
if('serviceWorker' in navigator){window.addEventListener('load',()=>{navigator.serviceWorker.register('./sw.js').catch(()=>{});});}
